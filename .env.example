# -----------------------------------------------------------------------------
# Stackivo environment variables
# -----------------------------------------------------------------------------
# Copy this file to `.env.local` for local dev. Do NOT commit `.env.local`.
# `NEXT_PUBLIC_*` vars are exposed to the browser.
# Everything else is server-only.
# -----------------------------------------------------------------------------

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Stackivo

# --- Supabase (required) -----------------------------------------------------
# Find these in Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Service-role key — server-only, full DB access. NEVER expose to the browser.
# Used by cron/webhook handlers and admin operations.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- OAuth (optional for local dev) ------------------------------------------
# Google OAuth is wired via Supabase. Configure provider credentials in
# Supabase Dashboard → Authentication → Providers → Google.
# These env vars are placeholders for direct integration if ever needed.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Razorpay subscriptions --------------------------------------------------
# Server-side keys (Dashboard → Account & Settings → API Keys).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Webhook signing secret (Dashboard → Webhooks → choose endpoint).
RAZORPAY_WEBHOOK_SECRET=

# Razorpay Plan IDs created in Dashboard → Subscriptions → Plans.
# Each maps to a (PlanId, BillingCycle) pair in src/features/billing.
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_YEARLY=
RAZORPAY_PLAN_BUSINESS_MONTHLY=
RAZORPAY_PLAN_BUSINESS_YEARLY=

# Browser-visible key id used by the Razorpay Checkout JS. Must match
# RAZORPAY_KEY_ID. Live key for prod, test key for dev.
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# --- Brevo (transactional emails) --------------------------------------------
# Used to send invoice / contract / proposal emails with PDF attachments.
# If unset, send actions still mint share links but skip the email step.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=
BREVO_SENDER_NAME=Stackivo

# Transport selection for transactional mail.
# - api = Brevo Transactional API
# - smtp = Brevo SMTP relay
BREVO_TRANSPORT=api

# Brevo SMTP relay credentials. Required only when BREVO_TRANSPORT=smtp.
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_SECURE=false
BREVO_SMTP_USER=
BREVO_SMTP_PASSWORD=

# Shared secret for the Brevo webhook. Add the SAME value to the Brevo
# webhook URL as `?token=<this value>` when configuring the webhook:
#   https://stackivo.me/api/webhooks/brevo?token=<this value>
# Leave blank to disable the webhook endpoint entirely (requests will 404).
BREVO_WEBHOOK_SECRET=

# Hard kill-switch for outbound transactional email.
#   unset  → live in production only (safe default).
#   true   → force live sending (production).
#   false  → force dry-run everywhere (stages / previews). Emails land in
#            `delivery_logs` with status='failed' / error='dry_run' and
#            never hit Brevo. Use this for preview deploys to protect
#            sender reputation.
EMAIL_LIVE_MODE=

# --- Upstash Redis (optional; enables production rate limiting) -------------
# Provision at https://upstash.com → Create database → REST API page.
# If unset, the rate-limiter fails open (no limit) to keep dev working.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# =============================================================================
# Observability (all optional — app works identically when unset)
# =============================================================================

# --- Sentry: error + performance tracking -----------------------------------
# Get from https://sentry.io → create a Next.js project → Settings → Client Keys.
# DSN is public-safe. Auth token is used only at build time for source-map uploads.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- PostHog: product analytics + session replay + feature flags ------------
# Sign up at https://posthog.com (select EU Cloud for DPDP compliance).
# Project Settings → API Keys.
NEXT_PUBLIC_POSTHOG_KEY=
# Use https://eu.i.posthog.com for EU region or https://us.i.posthog.com for US.
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# --- Alerting: Slack incoming webhook ---------------------------------------
# Create in Slack: Apps → Incoming Webhooks → Add → choose channel.
# Used by /api/cron/monitor to page the team on billing / delivery failures.
OPS_SLACK_WEBHOOK_URL=

# --- Vercel Cron authentication ---------------------------------------------
# Any random 32+ char string. Vercel Cron sends this as
# `Authorization: Bearer <CRON_SECRET>`. Without it, /api/cron/* returns 401.
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# --- Build / runtime tags (automatically set on Vercel) ---------------------
# Override locally if needed. Vercel sets VERCEL_GIT_COMMIT_SHA and VERCEL_ENV
# automatically in Preview + Production builds.
# NEXT_PUBLIC_COMMIT_SHA=
# NEXT_PUBLIC_RUNTIME_ENV=

# --- Conversion: Microsoft Clarity heatmaps + replay -----------------------
# Free unlimited heatmaps, scroll, click maps, and session replay. Get the
# project id from https://clarity.microsoft.com → Settings → Setup. Unset
# → script never loads, so safe to leave blank in dev / preview.
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# --- Conversion: Cal.com booking embed --------------------------------------
# Direct URL to your Cal.com event (e.g. https://cal.com/jaksh/founder-chat).
# Embedded as an iframe at /talk. Unset → /talk renders an honest "coming
# soon" stub.
NEXT_PUBLIC_CAL_COM_URL=

# --- Conversion: Loom demo video --------------------------------------------
# Public Loom *embed* URL (https://www.loom.com/embed/<id>). Embedded as
# iframe at /demo. Unset → /demo renders a placeholder + signup CTA.
NEXT_PUBLIC_LOOM_DEMO_URL=

# --- Conversion: Brevo newsletter list --------------------------------------
# Numeric list id from Brevo → Contacts → Lists. New email subscribers from
# the footer / exit-intent modal land in this list. Unset → leads still
# captured (founder gets an email), but not added to a Brevo list.
BREVO_NEWSLETTER_LIST_ID=

# --- Stackivo AI workflows --------------------------------------------------
# Server-only Groq credentials for contextual workflow draft generation.
# Leave GROQ_API_KEY blank to disable hosted inference in local development.
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# --- Support system: Crisp Live Chat ----------------------------------------
# Browser-safe website id, embedded into the chat widget script. Get it from
# Crisp Dashboard → Settings → Setup Instructions → "Website ID".
# Unset → the widget + identity bridge skip themselves.
NEXT_PUBLIC_CRISP_WEBSITE_ID=
# Server-only API credentials. Used for delete-on-soft-delete fan-out and
# webhook responses. Crisp Dashboard → Plugins → Marketplace → "Build new
# plugin" → set production scopes → API tokens.
CRISP_API_IDENTIFIER=
CRISP_API_KEY=
# Shared secret configured on the Crisp webhook subscription. The webhook
# route rejects deliveries without a matching X-Crisp-Signature.
CRISP_WEBHOOK_SECRET=

# --- Support system: Zoho Desk ----------------------------------------------
# Public help-center URL (custom domain or subdomain) used by the in-app
# Help button to deep-link to the KB. Unset → "Browse help articles"
# affordance hides itself.
NEXT_PUBLIC_ZOHO_DESK_HELP_URL=
# REST API credentials. See SUPPORT_SYSTEM_SETUP.md for the OAuth Self-Client
# flow that mints these. Org id scopes every call to a single Zoho Desk org.
ZOHO_DESK_ORG_ID=
ZOHO_DESK_ACCESS_TOKEN=
ZOHO_DESK_DEPARTMENT_ID=
# Regional API base. Pick the one matching your Zoho data centre:
#   IN  → https://desk.zoho.in     (default; India accounts)
#   EU  → https://desk.zoho.eu
#   US  → https://desk.zoho.com
ZOHO_DESK_API_BASE=https://desk.zoho.in
# Webhook shared secret. Generated by you, configured in Zoho Desk webhooks
# UI, verified by the route. Without it, the route returns 404.
ZOHO_DESK_WEBHOOK_SECRET=


CRISP_API_IDENTIFIER=your-plugin-identifier
CRISP_API_KEY=your-plugin-key
